generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Activity {
  id          Int      @id @default(autoincrement())
  sourceId    String   @unique
  source      String
  type        String
  title       String
  description String?
  url         String?
  timestamp   DateTime
  metadata    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([timestamp])
  @@index([source])
}

model Report {
  id            Int      @id @default(autoincrement())
  startDate     DateTime
  endDate       DateTime
  narrative        String   @db.Text
  themes           Json
  categories       Json
  executiveSummary Json?
  insights         Json
  metrics          Json
  activityCount Int
  createdAt     DateTime @default(now())

  @@index([startDate, endDate])
}
